FLASK_APP=run.py

FLASK_DEBUG=1

# Host port exposed by Docker Compose
APP_PORT=8000

# Path to the SQLite programs database on the host machine.
# Leave as ./instance/programs.db to use the default database shipped with the project.
PROGRAMS_DB_PATH=./instance/programs.db
ADMIN_PASSWORD=uma-password-forte-aqui
SECRET_KEY=uma-secret-key-grande-aqui